{
  "enabled": true,
  "name": "Git Commit After Task",
  "description": "Automatically commits changes to git after tests pass for each completed task, using conventional commit format",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "askAgent",
    "prompt": "First, run the test suite with 'trading_copilot/.venv/bin/pytest trading_copilot/tests/ -v --tb=short'. Only if ALL tests pass, check if there are uncommitted changes in the trading_copilot directory. If tests pass AND there are changes, create a git commit with a conventional commit message describing what was implemented. Use format: feat(component): description. Do not push the commit. If tests fail, do NOT commit - instead report the test failures."
  }
}